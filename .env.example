# ─── Server ──────────────────────────────────────────────────────────────────
# Port the Express server listens on (Railway/Vercel sets this automatically)
PORT=3000

# ─── Analytics (optional) ────────────────────────────────────────────────────
# Self-hosted Umami analytics. Remove the script tag in client/index.html if unused.
VITE_ANALYTICS_ENDPOINT=https://your-umami-instance.com
VITE_ANALYTICS_WEBSITE_ID=your-website-id

# ─── Google Maps (optional) ───────────────────────────────────────────────────
# Only needed if using the MapView component. Proxied through forge.butterfly-effect.dev
VITE_FRONTEND_FORGE_API_KEY=your-forge-api-key
VITE_FRONTEND_FORGE_API_URL=https://forge.butterfly-effect.dev
